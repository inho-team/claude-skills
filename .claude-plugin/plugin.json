{
  "name": "qe-framework",
  "version": "3.0.14",
  "description": "QE Framework v2.14.0 — High-Performance AI Engineering with GSD-Native PSE Loop (Plan-Spec-Execute) and Haiku Swarm.",
  "author": { "name": "inho-team" },
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start.mjs\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-tool-use.mjs\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-compact.mjs\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/post-tool-use.mjs\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-handler.mjs\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/prompt-check.mjs\"",
            "timeout": 8000
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/notification.mjs\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/teammate-idle.mjs\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/task-completed.mjs\"",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "agents": [
    "./agents/Earchive-executor.md",
    "./agents/Ecode-debugger.md",
    "./agents/Ecode-doc-writer.md",
    "./agents/Ecode-quality-supervisor.md",
    "./agents/Ecode-reviewer.md",
    "./agents/Ecode-test-engineer.md",
    "./agents/Ecommit-executor.md",
    "./agents/Ecompact-executor.md",
    "./agents/Edeep-researcher.md",
    "./agents/Edoc-generator.md",
    "./agents/Edocs-supervisor.md",
    "./agents/Eanalysis-supervisor.md",
    "./agents/Egrad-writer.md",
    "./agents/Ehandoff-executor.md",
    "./agents/Epm-planner.md",
    "./agents/Eprofile-collector.md",
    "./agents/Eqa-orchestrator.md",
    "./agents/Erefresh-executor.md",
    "./agents/Esecurity-officer.md",
    "./agents/Esupervision-orchestrator.md",
    "./agents/Etask-executor.md"
  ]
}
