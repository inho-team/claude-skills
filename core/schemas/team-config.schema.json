{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qe-framework/core/schemas/team-config.schema.json",
  "title": "QE AI Team Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "mode",
    "roles",
    "runners",
    "policies"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema / config version. Must be 1."
    },
    "mode": {
      "type": "string",
      "enum": [
        "single-model",
        "multi-model",
        "hybrid",
        "tiered-model"
      ],
      "description": "Workflow orchestration mode."
    },
    "default_language": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "description": "ISO language tag used for generated artifacts (e.g., en or en-US)."
    },
    "roles": {
      "type": "object",
      "description": "Role to runner assignments. Must include planner, implementer, reviewer, and supervisor; additional roles follow the same schema.",
      "additionalProperties": {
        "$ref": "#/$defs/roleDefinition"
      },
      "required": [
        "planner",
        "implementer",
        "reviewer",
        "supervisor"
      ],
      "properties": {
        "planner": {
          "$ref": "#/$defs/roleDefinition"
        },
        "implementer": {
          "$ref": "#/$defs/roleDefinition"
        },
        "reviewer": {
          "$ref": "#/$defs/roleDefinition"
        },
        "supervisor": {
          "$ref": "#/$defs/roleDefinition"
        }
      }
    },
    "runners": {
      "type": "object",
      "description": "Named runner instances used by roles. Multiple roles may share a runner, or a provider may appear more than once with different models and commands.",
      "additionalProperties": false,
      "patternProperties": {
        ".+": {
          "$ref": "#/$defs/runnerConfig"
        }
      }
    },
    "providers": {
      "type": "object",
      "description": "Optional provider-level overrides that apply when multiple runners share a provider.",
      "additionalProperties": {
        "$ref": "#/$defs/providerOverride"
      }
    },
    "policies": {
      "$ref": "#/$defs/policyConfig"
    }
  },
  "$defs": {
    "roleDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runner",
        "responsibility"
      ],
      "properties": {
        "runner": {
          "type": "string"
        },
        "responsibility": {
          "type": "string"
        }
      }
    },
    "providerOverride": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_ms": {
          "type": "integer",
          "minimum": 1000
        },
        "command": {
          "$ref": "#/$defs/providerCommand"
        }
      }
    },
    "runnerConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "display_name": {
          "type": "string"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 1000
        },
        "command": {
          "$ref": "#/$defs/providerCommand"
        }
      }
    },
    "providerCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executable",
        "args"
      ],
      "properties": {
        "executable": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "policyConfig": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "max_remediation_rounds",
        "reviewer_can_edit",
        "implementer_can_modify_spec"
      ],
      "properties": {
        "max_remediation_rounds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "default": 2,
          "description": "Number of remediation loops allowed before escalation. Defaults to 2."
        },
        "reviewer_can_edit": {
          "type": "boolean",
          "default": false,
          "description": "Whether reviewers may commit code changes. Defaults to false."
        },
        "implementer_can_modify_spec": {
          "type": "boolean",
          "default": false,
          "description": "Whether implementers may change planner-authored specs. Defaults to false."
        },
        "require_review_before_complete": {
          "type": "boolean",
          "default": true,
          "description": "Require review + supervision gate before marking work complete. Defaults to true."
        },
        "enforce_specific_remediation": {
          "type": "boolean",
          "default": true,
          "description": "Require reviewer and supervisor outputs to include concrete remediation steps with file targets and verification instructions."
        },
        "default_runner_by_complexity": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "low": {
              "type": "string",
              "description": "Preferred runner for trivial or mechanical work."
            },
            "medium": {
              "type": "string",
              "description": "Preferred runner for normal implementation and review work."
            },
            "high": {
              "type": "string",
              "description": "Preferred runner for planning, hard debugging, and final judgment."
            }
          },
          "description": "Optional complexity-to-runner mapping used by tiered-model setups."
        }
      }
    }
  }
}
