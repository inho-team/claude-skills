{
  "version": 1,
  "mode": "multi-model",
  "default_language": "en",
  "roles": {
    "planner": {
      "runner": "claude_planner",
      "responsibility": "Create and refine executable specs"
    },
    "implementer": {
      "runner": "codex_implementer",
      "responsibility": "Implement approved task items"
    },
    "reviewer": {
      "runner": "gemini_reviewer",
      "responsibility": "Independently review implementation quality and regressions"
    },
    "supervisor": {
      "runner": "claude_supervisor",
      "responsibility": "Make the final pass or remediation decision"
    }
  },
  "runners": {
    "claude_planner": {
      "provider": "claude",
      "model": "sonnet",
      "display_name": "Claude Planner",
      "timeout_ms": 300000,
      "command": {
        "executable": "C:\\Users\\Triphos\\AppData\\Roaming\\npm\\claude.cmd",
        "args": [
          "--print",
          "--append-system-prompt",
          "{system_prompt}",
          "--permission-mode",
          "plan",
          "--model",
          "{model}"
        ]
      }
    },
    "codex_implementer": {
      "provider": "codex",
      "model": "gpt-5-codex",
      "display_name": "Codex Implementer",
      "timeout_ms": 600000,
      "command": {
        "executable": "C:\\Users\\Triphos\\AppData\\Roaming\\npm\\codex.cmd",
        "args": [
          "exec",
          "--sandbox",
          "workspace-write",
          "--skip-git-repo-check",
          "--cd",
          "{cwd}",
          "--model",
          "{model}",
          "--output-last-message",
          "{output_file}",
          "-"
        ]
      }
    },
    "gemini_reviewer": {
      "provider": "gemini",
      "model": "gemini-2.5-pro",
      "display_name": "Gemini Reviewer",
      "timeout_ms": 300000,
      "command": {
        "executable": "C:\\Users\\Triphos\\AppData\\Roaming\\npm\\gemini.cmd",
        "args": [
          "--prompt",
          "",
          "--approval-mode",
          "plan",
          "--model",
          "{model}"
        ]
      }
    },
    "claude_supervisor": {
      "provider": "claude",
      "model": "opus",
      "display_name": "Claude Supervisor",
      "timeout_ms": 300000,
      "command": {
        "executable": "C:\\Users\\Triphos\\AppData\\Roaming\\npm\\claude.cmd",
        "args": [
          "--print",
          "--append-system-prompt",
          "{system_prompt}",
          "--permission-mode",
          "plan",
          "--model",
          "{model}"
        ]
      }
    }
  },
  "policies": {
    "max_remediation_rounds": 2,
    "reviewer_can_edit": false,
    "implementer_can_modify_spec": false,
    "require_review_before_complete": true
  }
}
