{
  "version": 1,
  "mode": "tiered-model",
  "default_language": "en",
  "roles": {
    "planner": {
      "runner": "claude_high",
      "responsibility": "Handle high-difficulty planning, architecture, and escalation decisions"
    },
    "implementer": {
      "runner": "claude_medium",
      "responsibility": "Implement approved task items and delegate only trivial subwork to the low tier"
    },
    "reviewer": {
      "runner": "claude_medium",
      "responsibility": "Review implementation quality and produce specific remediation instructions"
    },
    "supervisor": {
      "runner": "claude_high",
      "responsibility": "Make the final pass or remediation decision with concrete acceptance criteria"
    }
  },
  "runners": {
    "claude_low": {
      "provider": "claude",
      "model": "haiku",
      "display_name": "Claude Low Tier",
      "timeout_ms": 300000,
      "command": {
        "executable": "claude",
        "args": [
          "--print",
          "--append-system-prompt",
          "{system_prompt}",
          "--permission-mode",
          "plan",
          "--model",
          "{model}"
        ]
      }
    },
    "claude_medium": {
      "provider": "claude",
      "model": "sonnet",
      "display_name": "Claude Medium Tier",
      "timeout_ms": 600000,
      "command": {
        "executable": "claude",
        "args": [
          "--print",
          "--append-system-prompt",
          "{system_prompt}",
          "--permission-mode",
          "plan",
          "--model",
          "{model}"
        ]
      }
    },
    "claude_high": {
      "provider": "claude",
      "model": "opus",
      "display_name": "Claude High Tier",
      "timeout_ms": 300000,
      "command": {
        "executable": "claude",
        "args": [
          "--print",
          "--append-system-prompt",
          "{system_prompt}",
          "--permission-mode",
          "plan",
          "--model",
          "{model}"
        ]
      }
    },
    "codex_low": {
      "provider": "codex",
      "model": "gpt-5-codex-mini",
      "display_name": "Codex Low Tier",
      "timeout_ms": 300000,
      "command": {
        "executable": "codex",
        "args": [
          "exec",
          "--skip-git-repo-check",
          "--cd",
          "{cwd}",
          "--model",
          "{model}",
          "--output-last-message",
          "{output_file}",
          "-"
        ]
      }
    },
    "codex_medium": {
      "provider": "codex",
      "model": "gpt-5-codex",
      "display_name": "Codex Medium Tier",
      "timeout_ms": 600000,
      "command": {
        "executable": "codex",
        "args": [
          "exec",
          "--skip-git-repo-check",
          "--cd",
          "{cwd}",
          "--model",
          "{model}",
          "--output-last-message",
          "{output_file}",
          "-"
        ]
      }
    },
    "codex_high": {
      "provider": "codex",
      "model": "gpt-5.4",
      "display_name": "Codex High Tier",
      "timeout_ms": 600000,
      "command": {
        "executable": "codex",
        "args": [
          "exec",
          "--skip-git-repo-check",
          "--cd",
          "{cwd}",
          "--model",
          "{model}",
          "--output-last-message",
          "{output_file}",
          "-"
        ]
      }
    }
  },
  "policies": {
    "max_remediation_rounds": 2,
    "reviewer_can_edit": false,
    "implementer_can_modify_spec": false,
    "require_review_before_complete": true,
    "enforce_specific_remediation": true,
    "default_runner_by_complexity": {
      "low": "claude_low",
      "medium": "claude_medium",
      "high": "claude_high"
    }
  }
}
